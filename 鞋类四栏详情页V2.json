        {
          "input_role": "aesthetic_inspiration_images",
          "input_mapping": {
            "image_index": 2
          },
          "display_label": "灵感源泉 / INSPIRATION",
          "ai_copywriting_directive": {
            "target_field": "description",
            "prompt": "分析用户上传的image2灵感图（鞋类设计灵感来源图），提取核心视觉特征（色彩、材质、氛围、图案元素、艺术美学），生成一段80字左右的高级感艺术描述。"
          },
          "description": "{{AI_GENERATED:灵感图的艺术化解析}}",
          "sub_components": [
            {
              "display_label": "AI 灵感分析 / AI INSPIRATION ANALYSIS",
              "ai_copywriting_directive": {
                "target_field": "bullet_points",
                "prompt": "从灵感图中提取4-5个关键视觉特征，生成带项目符号的分析要点。"
              }
            },
            {
              "display_label": "情绪关键词 / MOOD KEYWORDS",
              "ai_copywriting_directive": {
                "target_field": "keywords",
                "prompt": "提取6-8个情绪关键词，中英文对照。"
              }
            }
          ]
        },
        {
          "output_role": "technical_sketch_image",
          "display_label": "技术图稿 / TECHNICAL SKETCH",
          "depends_on": "final_render_image",
          "sub_components": [
            {
              "display_label": "AI 结构转译逻辑 / STRUCTURAL TRANSLATION LOGIC",
              "ai_copywriting_directive": {
                "target_field": "bullet_points",
                "prompt": "列出4-5个从灵感图到技术图稿的结构转译要点，如：几何形态→鞋身轮廓线。"
              }
            }
          ]
        },
        {
          "input_role": "final_render_image",
          "display_label": "成品效果图 / FINAL RENDER",
          "sub_components": [
            {
              "display_label": "材料建议 / MATERIALS",
              "ai_copywriting_directive": {
                "target_field": "material_list",
                "prompt": "列出4-5种推荐鞋材，包含材质描述，如：小牛皮、麂皮、橡胶大底等。"
              }
            },
            {
              "display_label": "工艺建议 / CRAFTSMANSHIP",
              "ai_copywriting_directive": {
                "target_field": "craft_list",
                "prompt": "列出4-5种鞋类工艺建议，带有图标标识，如：手工缝线、Goodyear沿条、注塑工艺等。"
              }
            },
            {
              "display_label": "系列风格定位 / STYLE DIRECTION",
              "ai_copywriting_directive": {
                "target_field": "style_analysis",
                "prompt": "分析鞋履系列风格：品牌定位、目标人群、用户画像、穿着场景。"
              }
            }
          ]
        },
        {
          "output_role": "model_presentation_images",
          "display_label": "上脚展示 / ON-FOOT PRESENTATION"
        }
      ]
    },
    {
      "section_id": "dna_section",
